# ===========================================================
# Plantilla de variables de entorno de PrepaTrack
# Copia este archivo como ".env" y reemplaza los valores.
# NUNCA subas el archivo .env real a GitHub (esta en .gitignore).
# ===========================================================

# --- Base de datos MySQL ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=tu_contrasena_mysql
DB_NAME=prepatrack

# Para una base de datos en la nube (Aiven, Railway, etc.)
# usa el host, usuario, contrasena, nombre y puerto que te entrega el proveedor:
# DB_HOST=mysql-xxxxx.aivencloud.com
# DB_PORT=3306

# --- Seguridad ---
# Clave secreta para firmar los tokens JWT. Usa un valor largo y aleatorio.
JWT_SECRET=cambia_esto_por_una_clave_secreta_larga

# --- Servidor ---
PORT=3000
